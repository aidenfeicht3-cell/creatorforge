# ─────────────────────────────────────────────
# CreatorForge AI — Environment Variables
# Copy this file to `.env.local` and fill in values.
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model overrides (optional). Used by the tiered plan system.
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-7
CLAUDE_MODEL_OPUS=claude-opus-4-7

# Google Gemini (optional fallback) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs from Stripe Dashboard > Products
STRIPE_PRO_PRICE_ID=
STRIPE_STUDIO_PRICE_ID=
