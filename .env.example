# ─────────────────────────────────────────────
# Snipd — Environment Variables
# Local:      copy this file to `.env.local` and fill in.
# Production: add these in Vercel → Settings → Environment Variables, then Redeploy.
# ─────────────────────────────────────────────

# ════════════════ REQUIRED ════════════════

# App — your live URL, NO trailing slash (used for Stripe redirects + share links)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase — auth + database.  https://supabase.com/dashboard → Project Settings → API
# Also turn ON: Authentication → Providers → Email → "Allow new users to sign up"
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq — powers the FREE tier (Llama 3.3 70B). Free, no card, no region locks.
# ⚠ Without this, free users fall back to PAID Claude. Always set it.
# https://console.groq.com
GROQ_API_KEY=
GROQ_BIG_MODEL=llama-3.3-70b-versatile

# Anthropic (Claude) — powers paid Creator + Studio quality. Pay-per-use; add a card.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MODEL_OPUS=claude-opus-4-8

# Stripe — payments.  https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs — Products → Creator ($15/mo + $120/yr), Studio ($39/mo + $312/yr)
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_PRICE_ID_ANNUAL=
STRIPE_STUDIO_PRICE_ID=
STRIPE_STUDIO_PRICE_ID_ANNUAL=

# ════════ OPTIONAL — adds power; the app runs without these ════════

# Replicate — premium images (Flux 1.1 Pro Ultra, ~$0.04/img, paid runs only).
# Free users always get free Pollinations images — no key needed.
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-1.1-pro-ultra

# ElevenLabs — AI Voiceover. Free tier: 10k characters/month.  https://elevenlabs.io
ELEVENLABS_API_KEY=

# Creatomate — the video render engine (powers the Clipper + the faceless
# Auto Video builder). Free tier ~50 renders/month.  https://creatomate.com
CREATOMATE_API_KEY=

# Pexels — free stock B-roll for the faceless Auto Video builder.
# https://www.pexels.com/api/
PEXELS_API_KEY=

# YouTube Data API v3 — real-data Channel Audit.
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Twitch — Stream Clipper (search + clips).  https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Rewardful — affiliate tracking (30% recurring). Public account ID for the script tag.
NEXT_PUBLIC_REWARDFUL_ID=
