# ─────────────────────────────────────────────
# CreatorForge AI — Environment Variables
# Copy this file to `.env.local` and fill in values.
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Founder backdoor — while in waitlist-only mode, anyone hitting /signup is
# routed to the waitlist UNLESS the URL includes ?key=<this value>.
# Keep this secret. Change it before going public.
FOUNDER_KEY=change-me-to-something-long-and-random

# Supabase — https://supabase.com/dashboard (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model overrides (optional). Used by the tiered plan system.
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-7
CLAUDE_MODEL_OPUS=claude-opus-4-7

# Groq — https://console.groq.com (free, no card, no region locks)
# Llama 3.3 70B for heavy tools, Llama 3.1 8B Instant for light tools.
GROQ_API_KEY=
GROQ_BIG_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Google Gemini — https://aistudio.google.com/apikey (region-restricted)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image


# Replicate — https://replicate.com/account/api-tokens
# Best path to Nano Banana / Imagen / Flux Pro if Gemini direct is blocked.
# Pay-as-you-go, ~$0.04 per image. Starts with $0 credit, requires billing setup.
REPLICATE_API_TOKEN=
# Models: black-forest-labs/flux-1.1-pro-ultra (default, best quality),
#         google/imagen-4-fast (cheaper), google/nano-banana,
#         ideogram-ai/ideogram-v3 (only if you want text rendered IN-image)
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-1.1-pro-ultra

# Stripe — https://dashboard.stripe.com/apikeys
# ElevenLabs voice generation — https://elevenlabs.io
# Free tier: 10k characters/month. Paid: $5/mo for 30k.
ELEVENLABS_API_KEY=

# YouTube Data API v3 — used for Channel Audit
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Twitch API — used for Stream Clipper (search + clips)
# https://dev.twitch.tv/console/apps — create app + get Client ID + Secret
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs from Stripe Dashboard > Products
STRIPE_PRO_PRICE_ID=
STRIPE_STUDIO_PRICE_ID=
